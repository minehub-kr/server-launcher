{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Minehub Server Launcher",
  "identifier": "kr.minehub.mclauncher",
  "build": {
    "beforeDevCommand": "pnpm dev",
    "beforeBuildCommand": "pnpm generate",
    "devUrl": "http://localhost:3000",
    "frontendDist": "../.output/public"
  },
  "app": {
    "withGlobalTauri": false,
    "windows": [
      {
        "title": "Minehub Server Launcher",
        "width": 1280,
        "height": 820,
        "minWidth": 1040,
        "minHeight": 680
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": false,
    "createUpdaterArtifacts": true,
    "targets": "all",
    "icon": ["icons/icon.png", "icons/icon.ico"],
    "macOS": {
      "signingIdentity": "-"
    }
  },
  "plugins": {
    "updater": {
      "active": true,
      "dialog": false,
      "endpoints": [
        "https://github.com/minehub-kr/server-launcher/releases/latest/download/latest.json"
      ],
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IENFOEZDQzBFRTdBRDlGOTEKUldTUm42M25Ec3lQemhYVGhmTXlIT1QveGRrK05FTnRhOWdqWUdtRE5iZkNmSE1lSVFvMXhkVzgK",
      "windows": {
        "installMode": "passive"
      }
    }
  }
}
